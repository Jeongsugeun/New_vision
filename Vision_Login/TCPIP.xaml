<Window x:Class="Vision_Login.TCPIP"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vision_Login"
        mc:Ignorable="d"
        Title="COMMUNICATION SETTINGS"
        Height="360" Width="720"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 전체 배경색 -->
        <SolidColorBrush x:Key="WindowBg"       Color="#1C2333"/>
        <SolidColorBrush x:Key="PanelBg"        Color="#242E42"/>
        <SolidColorBrush x:Key="BorderBrush"     Color="#3A4560"/>
        <SolidColorBrush x:Key="AccentBlue"      Color="#2D6BE4"/>
        <SolidColorBrush x:Key="AccentBlueDark"  Color="#1E4DB7"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#E8EDF5"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#8A9BB8"/>
        <SolidColorBrush x:Key="InputBg"         Color="#1C2535"/>
        <SolidColorBrush x:Key="InputBorder"     Color="#3A4560"/>
        <SolidColorBrush x:Key="BtnSecBg"        Color="#2A3347"/>
        <SolidColorBrush x:Key="BtnSecBorder"    Color="#3A4560"/>
        <SolidColorBrush x:Key="SectionTitle"    Color="#4A9EF5"/>

        <!-- ComboBox 스타일 -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"           Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"           Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"          Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Height"               Value="34"/>
            <Setter Property="Padding"              Value="10,0,4,0"/>
            <Setter Property="FontSize"             Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <Path Data="M 0 0 L 6 6 L 12 0"
                                          Stroke="{StaticResource TextSecondary}"
                                          StrokeThickness="1.5"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"
                                          StrokeLineJoin="Round"/>
                                </Grid>
                            </Border>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                         Background="Transparent" BorderThickness="0" Opacity="0"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" Focusable="False">
                                <Border Background="{StaticResource PanelBg}"
                                        BorderBrush="{StaticResource InputBorder}"
                                        BorderThickness="1" CornerRadius="4">
                                    <ItemsPresenter/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
                    <Setter Property="Padding"     Value="10,6"/>
                    <Setter Property="FontSize"    Value="13"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource InputBorder}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>

        <!-- TextBox 스타일 -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"       Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Height"           Value="34"/>
            <Setter Property="Padding"          Value="10,0"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button (파란색 Connect) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource AccentBlueDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button (Disconnect) -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource BtnSecBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BtnSecBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33405A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 라벨 스타일 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width"      Value="90"/>
        </Style>
    </Window.Resources>

    <!-- 외부 그림자 효과 -->
    <Border CornerRadius="10"
            Background="{StaticResource WindowBg}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.6" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── 타이틀 바 ── -->
            <Border Grid.Row="0"
                    Background="{StaticResource WindowBg}"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets"
               Foreground="White" FontSize="25" VerticalAlignment="Center" Margin="8,0,10,0"/>
                        <TextBlock Text="Port&amp;TCP/IP" Foreground="White"
               FontSize="25" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,24,0"/>
                    </StackPanel>
                    <!-- 닫기 버튼 -->
                    <Button x:Name="btnClose"
                            Content="✕"
                            Width="28" Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,14,0"
                            Foreground="{StaticResource TextSecondary}"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"
                            Click="BtnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#E04040"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ── 구분선 ── -->
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                       Fill="{StaticResource BorderBrush}"/>

            <!-- ── 본문 ── -->
            <Grid Grid.Row="1" Margin="20,16,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ══════════ Serial 패널 ══════════ -->
                <Border Grid.Column="0"
                        Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,16">
                    <StackPanel>
                        <!-- 섹션 제목 -->
                        <TextBlock Text="Serial"
                                   Foreground="{StaticResource SectionTitle}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Margin="0,0,0,18"/>

                        <!-- Port Set -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Port Set"
                                       Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      x:Name="cmbPortSet"
                                      Style="{StaticResource DarkComboBox}"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4"/>
                            </ComboBox>
                        </Grid>

                        <!-- Port Number -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Port number"
                                       Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      x:Name="cmbPortNumber"
                                      Style="{StaticResource DarkComboBox}"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="COM1"/>
                                <ComboBoxItem Content="COM2"/>
                                <ComboBoxItem Content="COM3"/>
                                <ComboBoxItem Content="COM4"/>
                            </ComboBox>
                        </Grid>

                        <!-- Baud Rate -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Baud rate"
                                       Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      x:Name="cmbBaudRate"
                                      Style="{StaticResource DarkComboBox}"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="9600"/>
                                <ComboBoxItem Content="19200"/>
                                <ComboBoxItem Content="38400"/>
                                <ComboBoxItem Content="115200"/>
                            </ComboBox>
                        </Grid>

                        <!-- 버튼 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    x:Name="btnSerialConnect"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnSerialConnect_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔗" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="Connect" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2"
                                    x:Name="btnSerialDisconnect"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnSerialDisconnect_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⛔" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="Disconnect" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ══════════ TCP/IP 패널 ══════════ -->
                <Border Grid.Column="2"
                        Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,16">
                    <StackPanel>
                        <!-- 섹션 제목 -->
                        <TextBlock Text="TCP/IP"
                                   Foreground="{StaticResource SectionTitle}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Margin="0,0,0,18"/>

                        <!-- Mode -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mode"
                                       Style="{StaticResource FieldLabel}"
                                       Width="Auto"/>
                            <ComboBox Grid.Column="1"
                                      x:Name="cmbMode"
                                      Style="{StaticResource DarkComboBox}"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Server"/>
                                <ComboBoxItem Content="Client"/>
                            </ComboBox>
                        </Grid>

                        <!-- IP -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="IP"
                                       Style="{StaticResource FieldLabel}"
                                       Width="Auto"/>
                            <TextBox Grid.Column="1"
                                     x:Name="txtIP"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="192.168.3.49"/>
                        </Grid>

                        <!-- Port -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Port"
                                       Style="{StaticResource FieldLabel}"
                                       Width="Auto"/>
                            <TextBox Grid.Column="1"
                                     x:Name="txtPort"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="9888"/>
                        </Grid>

                        <!-- 버튼 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    x:Name="btnTcpConnect"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnTcpConnect_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔗" FontSize="13" Margin="0,0,6,0"/>
                                    <TextBlock Text="Connect" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2"
                                    x:Name="btnTcpDisconnect"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnTcpDisconnect_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⛔" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="Disconnect" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
