<Window x:Class="Vision_Login.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visionplus" Height="600" Width="1000"
        WindowStyle="None" AllowsTransparency="true" Background="Transparent" WindowStartupLocation="CenterScreen">

    <Border CornerRadius="30" Background="#1E1E1E" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" Color="Black" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6.5*" />
                <ColumnDefinition Width="3.5*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0" ClipToBounds="True">
                <Border CornerRadius="30,0,0,30">
                    <Border.Background>
                        <ImageBrush ImageSource="Main.jpg" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>
            </Grid>

            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="20,10,20,0" Height="540">

                <Button x:Name="btnClose" 
                        Content="✕" 
                        FontSize="20" 
                        Foreground="White"   
                        HorizontalAlignment="Right" 
                        Margin="0,0,5,0"
                        Background="Transparent" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        Click="btnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#FF4C4C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Text="LOGIN" 
           FontSize="36" 
           FontWeight="Bold" 
           HorizontalAlignment="Center" 
           Margin="0,60,0,40" 
           Foreground="#E0FFFF">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FFFF" 
                          BlurRadius="20" 
                          ShadowDepth="0" 
                          Opacity="1.0" />
                    </TextBlock.Effect>
                </TextBlock>

                <Grid Margin="0,0,0,20">
                    <ComboBox x:Name="cmbUserLevel" Height="45" VerticalContentAlignment="Center"
              Padding="40,0,10,0"
              Foreground="White"
              SelectionChanged="cmbUserLevel_SelectionChanged">
                        <ComboBox.Template>
                            <ControlTemplate TargetType="ComboBox">
                                <Grid>
                                    <Border x:Name="MainBorder"
                            Background="#1A1A2E"
                            BorderBrush="#2A6A7A"
                            BorderThickness="1.5"
                            CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>

                                            <ContentPresenter Grid.Column="0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              VerticalAlignment="Center"
                                              Margin="40,0,0,0"/>

                                            <TextBlock Grid.Column="1"
                                       Text="▼" FontSize="10"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                                            <ToggleButton Grid.ColumnSpan="2"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          BorderThickness="0" Background="Transparent">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                        </Grid>
                                    </Border>

                                    <Popup x:Name="PART_Popup"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           Focusable="False">
                                        <Border Background="#1A1A2E"
                                BorderBrush="#2A6A7A"
                                BorderThickness="1.5"
                                CornerRadius="8"
                                Margin="0,4,0,0"
                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                            <ItemsPresenter/>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- ComboBox 트리거는 MainBorder만 -->
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="MainBorder" Property="BorderBrush" Value="#4FB0D6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>

                            </ControlTemplate>
                        </ComboBox.Template>

                        <ComboBox.Resources>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#1A1A2E"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBoxItem">
                                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="5">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!-- IsSelected는 기본 배경색 유지 -->
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#1A1A2E"/>
                                                </Trigger>
                                                <!-- IsMouseOver, IsHighlighted만 색 변경 -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#2A3A5A"/>
                                                </Trigger>
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#2A3A5A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.Resources>

                        <ComboBoxItem Content="Operator" IsSelected="True"/>
                        <ComboBoxItem Content="Engineer"/>
                        <ComboBoxItem Content="Admin"/>
                    </ComboBox>

                    <TextBlock Text="👤" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0" Foreground="White"/>
                </Grid>
                
                <Grid x:Name="gridPassword" Margin="0,0,0,40" Visibility="Visible">
                    <Border Background="#1A1A2E"
            BorderBrush="#2A6A7A"
            BorderThickness="1.5"
            CornerRadius="8">
                        <Grid>
                            <PasswordBox x:Name="txtPassword" Height="45" VerticalContentAlignment="Center"
                         Padding="40,0,10,0"
                         Foreground="White"
                         BorderThickness="0"
                         Background="Transparent"
                         PasswordChanged="txtPassword_PasswordChanged">
                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="PasswordBox">
                                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </PasswordBox.Style>
                            </PasswordBox>

                            <TextBlock x:Name="txtPasswordPlaceholder" Text="Password"
                       VerticalAlignment="Center" HorizontalAlignment="Left"
                       Margin="42,0,0,0" Foreground="White" IsHitTestVisible="False"/>
                            <TextBlock Text="🔒" VerticalAlignment="Center" HorizontalAlignment="Left"
                       Margin="15,0,0,0" Foreground="White"/>
                        </Grid>
                    </Border>
                </Grid>

                <Button Content="Login Now" Height="55" Foreground="White" FontSize="18" FontWeight="SemiBold" Cursor="Hand" Click="btnLogin_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#4FB0D6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#3A8FB7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Text="Ver. 2026.04.27" Foreground="#4FB0D6" FontSize="11" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>