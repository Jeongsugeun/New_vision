<Window x:Class="Vision_Login.Cam1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vision_Login"
        mc:Ignorable="d"
        Title="VISIONPLUS"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#1E1E1E" Height="1080" Width="1920">

    <!--스크롤바 꾸미기(시작)--> 
    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="6">
                            <Border Background="#2A2A2A" CornerRadius="3" Margin="1,0"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#666666" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <!--스크롤바 꾸미기(종료)-->

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <!--화면 세로 비율 조정-->
        <Grid.RowDefinitions>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="20*"/>
            <RowDefinition Height="30*"/>
            <!--<RowDefinition Height="74*"/>-->
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>

        <!--화면 가로 비율 조정-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="8*"/>
            <ColumnDefinition Width="15*"/>
            <ColumnDefinition Width="46*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>

        <!--좌측 버튼(AUTO/MANUAL, CONFIG, EXIT)-->
        <StackPanel Grid.Column="0" Grid.Row="1" Grid.RowSpan="5" Background="#252526">
            <!--AUTO/MANUAL-->
            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,0,5"
                    Click="Btn_Toggle_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Btn_OperationMode" Background="Transparent" Padding="5" CornerRadius="8">
                            <StackPanel>
                                <TextBlock x:Name="Btn_Icon" Text="&#xE895;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="40"
                                           Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="Btn_Label" Text="AUTO"
                                           Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Btn_OperationMode" Property="Background" Value="#3a3a3a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Btn_OperationMode" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!--CONFIG-->
            <Button x:Name="BtnConfig" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,0,5" Click="Btn_Config_Click">
                <Button.RenderTransformOrigin>0.5, 0.5</Button.RenderTransformOrigin>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Btn_Config" Background="Transparent" Padding="5" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="40"
                                           Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="CONFIG" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Btn_Config" Property="Background" Value="#3a3a3a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Btn_Config" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!--EXIT-->
            <Button x:Name="BtnExit" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,0,5" Click="Btn_Exit_Click">
                <Button.RenderTransformOrigin>0.5, 0.5</Button.RenderTransformOrigin>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Btn_Exit" Background="Transparent" Padding="5" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="40"
                                           Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="EXIT" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Btn_Exit" Property="Background" Value="#3a3a3a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Btn_Exit" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- 헤더 배경 -->
        <Border Grid.Column="0" Grid.ColumnSpan="8" Grid.Row="0"
                Background="#2C3A47" BorderBrush="#2A3A47" BorderThickness="0,0,0,1"/>

        <!--Device 버튼-->
        <Button x:Name="BtnDevice" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
                VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                BorderThickness="0" Padding="0" MouseDoubleClick="btnDevice_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="15" Padding="20,10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#7A9AB8" Offset="0.0"/>
                                <GradientStop Color="#5C7A96" Offset="0.4"/>
                                <GradientStop Color="#232D36" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="DEVICE" Foreground="#B0B8C0" FontWeight="Bold" FontSize="20" HorizontalAlignment="Left"/>
                            <TextBlock Text="INSPECTOR-A" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <StackPanel Grid.Column="2" Grid.Row="0" VerticalAlignment="Center" Margin="10,0,0,0">
            <TextBlock Text="LOTID" Foreground="Gray" FontSize="20" Margin="0,0,0,2"/>
            <TextBlock Text="260312-PCB-005" Foreground="#70AD47" FontWeight="Bold" FontSize="20"/>
        </StackPanel>

        <Button x:Name="Btn_NameChange" Grid.Column="3" Grid.Row="0" VerticalAlignment="Center"
Background="Transparent" BorderThickness="0" Cursor="Hand" MouseDoubleClick="btnVisionPlus_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="#1E2A35" CornerRadius="5" Padding="0,10">
                        <TextBlock Text="VISIONPLUS"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="White"
                   FontSize="35"
                   FontWeight="Bold"
                   Opacity="0.9">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="Black" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#1E2A35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button x:Name="Btn_IP" Grid.Column="4" Grid.ColumnSpan="3" Grid.Row="0"
VerticalAlignment="Center" HorizontalAlignment="Right"
Margin="0,0,30,0"
Cursor="Hand"
MouseDoubleClick="BtnIPPort_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="IP:" Foreground="Gray" FontSize="20"/>
                    <TextBlock Text="192.168.0.100" Foreground="White" FontSize="20"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="PORT:" Foreground="#999999" FontSize="20"/>
                    <TextBlock Text="9888" Foreground="White" FontSize="20"/>
                </StackPanel>
            </StackPanel>
        </Button>

        <StackPanel Grid.Column="6" Grid.ColumnSpan="2" Grid.Row="0" VerticalAlignment="Center"
                    HorizontalAlignment="Right" Margin="0,0,20,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Ver." Foreground="Gray" FontSize="20"/>
                <TextBlock Text="2026.04.17.001" Foreground="White" FontSize="20" Margin="5,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5,0,0">
                <TextBlock x:Name="TxtCurrentTime" Text="2026.04.17 16:56:00"
                           Foreground="White" FontSize="20" VerticalAlignment="Center"/>
                <TextBlock Text=" &#xE121;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                           VerticalAlignment="Center">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="#FFFFFF"/>
                    </TextBlock.Foreground>
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FFFF" BlurRadius="15" ShadowDepth="0" Opacity="1.0"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- 툴바 버튼 (Row=1, Column=1~4) -->
        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" 
Background="#1E1E1E" Margin="3,5,3,5" CornerRadius="5">
            <WrapPanel Orientation="Horizontal" Margin="5,3" VerticalAlignment="Center">

                <!-- Grab -->
                <Button Cursor="Hand" Margin="3,2" Padding="10,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                    BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets"
                               FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Grab" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Live -->
                <Button Cursor="Hand" Margin="3,2" Padding="10,5" Click="LiveButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
            BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE102;" FontFamily="Segoe MDL2 Assets"
                       FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Live" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Test -->
                <Button Cursor="Hand" Margin="3,2" Padding="10,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                    BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xF6FA;" FontFamily="Segoe MDL2 Assets"
                               FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Test" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Settings -->
                <Button Cursor="Hand" Margin="3,2" Padding="10,5" Click="btnCam1Settings_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                    BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                               FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Settings" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Load -->
                <Button Cursor="Hand" Margin="3,2" Padding="10,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                    BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets"
                               FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Load" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Save -->
                <Button Cursor="Hand" Margin="3,2" Padding="10,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                    BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                               FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Save" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Measure -->
                <Button Cursor="Hand" Margin="3,2" Padding="10,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                    BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xED5E;" FontFamily="Segoe MDL2 Assets"
                               FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Measure" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </WrapPanel>
        </Border>

        <!--User Level(Combobox)-->
        <Grid Grid.Column="7" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="User Level:" Foreground="Gray" FontSize="20"
                       VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0"/>
            <ComboBox Grid.Column="1" x:Name="cmbUserLevel" SelectedIndex="2"
                      Foreground="White" FontSize="20" VerticalAlignment="Stretch"
                      Margin="0,5,0,5" VerticalContentAlignment="Center" Padding="5,0">
                <ComboBox.Resources>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#3A3D42"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4A5A6A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3A3D42"/>
                                        </Trigger>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="#4A5A6A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ComboBox.Resources>
                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="MainBorder" Background="#3A3D42" CornerRadius="5"
                                BorderBrush="#555860" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton Grid.ColumnSpan="2"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              BorderThickness="0">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center" IsHitTestVisible="False" Margin="8,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="&#x25BC;" FontSize="10" Foreground="White"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
                                <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Border Background="#3A3D42" BorderBrush="#555860" BorderThickness="1"
                                            CornerRadius="5"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#4A5A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ComboBox.Template>
                <ComboBoxItem Content="Operator"/>
                <ComboBoxItem Content="Engineer"/>
                <ComboBoxItem Content="Admin"/>
            </ComboBox>
        </Grid>

        <!-- ══════════════════════════════════════════════════════ -->
        <!--  메인 콘텐츠 영역 (Row2~4, Col1~7)                     -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="7" Grid.RowSpan="4" Margin="5,5,10,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="17.5*"/>
                <ColumnDefinition Width="1.5*"/>
                <!-- 좌측 Parameter -->
                <ColumnDefinition Width="50*"/>
                <!-- 중앙 CAM 라이브 -->
                <ColumnDefinition Width="20*"/>
                <!-- 우측 설정 패널 -->
            </Grid.ColumnDefinitions>

            <!-- ── 좌측: Parameter 패널 ── -->
            <Border Grid.Column="0" Background="#252526" CornerRadius="5" Margin="0,0,5,0" Grid.ColumnSpan="2" Grid.RowSpan="4">
                <Grid>
                    <!-- Parameter 헤더 -->
                    <Border Background="#2A2D2E" CornerRadius="5,5,0,0" Padding="10,8">
                        <!--<StackPanel Orientation="Horizontal">
                            <TextBlock Text="Parameter" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>-->
                    </Border>

                    <!-- Parameter 내용 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Grid.RowSpan="2">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Width" Value="6"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ScrollBar">
                                            <Grid Background="Transparent" Width="6">
                                                <Border Background="#2A2A2A" CornerRadius="3" Margin="1,0"/>
                                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                    <Track.Thumb>
                                                        <Thumb>
                                                            <Thumb.Template>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="#666666" CornerRadius="3"/>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <!--CheckBox-->
                            <Style TargetType="CheckBox" x:Key="BlueCheckStyle">
                                <Setter Property="Width" Value="18"/>
                                <Setter Property="Height" Value="18"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Border x:Name="ChkBorder"
                                Width="18" Height="18" CornerRadius="2"
                                BorderBrush="#777" BorderThickness="1"
                                Background="#2A2D2E">
                                                <Path x:Name="ChkMark"
                                  Visibility="Collapsed"
                                  Stroke="White" StrokeThickness="2"
                                  Data="M 3 9 L 7 13 L 14 4"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ChkBorder" Property="Background" Value="#1E88FF"/>
                                                    <Setter TargetName="ChkBorder" Property="BorderBrush" Value="#1E88FF"/>
                                                    <Setter TargetName="ChkMark"   Property="Visibility"  Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
