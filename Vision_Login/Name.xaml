<Window x:Class="Vision_Login.Name"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vision_Login"
        mc:Ignorable="d"

        Title="Program Name"
        Height="360"
        Width="680"

        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border Background="#11181F"
            BorderBrush="#1E3A5F"
            BorderThickness="1"
            CornerRadius="14">

        <Grid Margin="28,22,28,28">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 상단 타이틀 바 -->
            <Grid Grid.Row="0" Margin="0,0,0,24">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 편집 아이콘 -->
                <TextBlock Grid.Column="0"
                           Text="&#xE70F;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="22"
                           Foreground="#A0B4C8"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <!-- 제목 -->
                <TextBlock Grid.Column="1"
                           Text="프로그램 이름 변경"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- X 닫기 버튼 -->
                <Button Grid.Column="2"
                        Width="36"
                        Height="36"
                        Content="✕"
                        Foreground="#A0B4C8"
                        FontSize="16"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="Btn_Cancel_Click">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1E2D3D"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>

                </Button>

            </Grid>

            <!-- 카드 영역 -->
            <Border Grid.Row="1"
                    Background="#161F29"
                    BorderBrush="#294861"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="24,22">

                <StackPanel>

                    <!-- 새 이름 (파란색 강조) -->
                    <TextBlock Text="새 이름"
                               Foreground="#3B9EFF"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,16"/>

                    <!-- 프로그램 이름 서브라벨 -->
                    <TextBlock Text="프로그램 이름"
                               Foreground="White"
                               FontSize="20"
                               Margin="0,0,0,8"/>

                    <!-- TextBox with placeholder -->
                    <Grid>

                        <TextBox x:Name="TxtProgramName"
                                 Height="52"
                                 FontSize="16"
                                 Foreground="White"
                                 Background="#0D1520"
                                 BorderBrush="#2A6496"
                                 BorderThickness="1.5"
                                 CaretBrush="White"
                                 Padding="16,0"
                                 VerticalContentAlignment="Center"
                                 Panel.ZIndex="1">

                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="7">
                                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#3DB7FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>

                        </TextBox>

                        <!-- Placeholder 텍스트 -->
                        <TextBlock Text="새 프로그램 이름을 입력하세요"
                                   Foreground="#3A5270"
                                   FontSize="16"
                                   Margin="18,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Panel.ZIndex="2">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=TxtProgramName}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                    </Grid>

                    <!-- 저장 버튼 -->
                    <Button Height="52"
                            Width="160"
                            HorizontalAlignment="Right"
                            Margin="0,24,0,0"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Btn_Save_Click">

                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2D8CFF" Offset="0"/>
                                <GradientStop Color="#0B5ED7" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="&#xE74E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="20"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Text="저장"
                                                   Foreground="White"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                </StackPanel>

            </Border>

        </Grid>

    </Border>

</Window>