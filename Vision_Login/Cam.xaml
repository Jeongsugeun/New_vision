<Window x:Class="Vision_Login.Cam"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vision_Login"
        PreviewKeyDown="Window_PreviewKeyDown"
        mc:Ignorable="d"
        Title="VISIONPLUS"
        WindowState="Maximized"       
        WindowStyle="None"            
        ResizeMode="NoResize"         
        Background="#1E1E1E" Height="1080" Width="1920">

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <!--화면 세로 비율 조정-->
        <Grid.RowDefinitions>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="74*"/>
            <RowDefinition Height="11*"/>
        </Grid.RowDefinitions>

        <!--화면 가로 비율 조정-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="8*"/>
            <ColumnDefinition Width="15*"/>
            <ColumnDefinition Width="46*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>

        <!--좌측 버튼(AUTO/MANUAL, CONFIG, EXIT)-->
        <StackPanel Grid.Column="0" Grid.Row="1" Grid.RowSpan="4" Background="#252526">
            <!--AUTO/MANUAL-->
            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,0,5"
        Click="Btn_Toggle_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Btn_OperationMode" Background="Transparent" Padding="5" CornerRadius="8">
                            <StackPanel>
                                <TextBlock x:Name="Btn_Icon"
                       Text="&#xE895;" 
                       FontFamily="Segoe MDL2 Assets" 
                       FontSize="40" 
                       Foreground="White" 
                       HorizontalAlignment="Center"/>
                                <TextBlock x:Name="Btn_Label"
                       Text="AUTO" 
                       Foreground="White" 
                       FontSize="20" 
                       HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Btn_OperationMode" Property="Background" Value="#3a3a3a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Btn_OperationMode" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <!--CONFIG-->
            <Button x:Name="BtnConfig" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,0,5" Click="Btn_Config_Click">
                <Button.RenderTransformOrigin>0.5, 0.5</Button.RenderTransformOrigin>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Btn_Config" Background="Transparent" Padding="5" CornerRadius="8">
                            <StackPanel>
                                <TextBlock x:Name="ConfigIcon"
                               Text="&#xE713;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="40"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                                <TextBlock Text="CONFIG"
                               Foreground="White"
                               FontSize="20"
                               HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Btn_Config" Property="Background" Value="#3a3a3a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Btn_Config" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!--EXIT-->
            <Button x:Name="BtnExit" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,0,5" Click="Btn_Exit_Click">
                <Button.RenderTransformOrigin>0.5, 0.5</Button.RenderTransformOrigin>
                <Button.RenderTransform>
                    <RotateTransform x:Name="ExitRotate" Angle="0"/>
                </Button.RenderTransform>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Btn_Exit" Background="Transparent" Padding="5" CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="&#xE7E8;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="40"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                                <TextBlock Text="EXIT"
                               Foreground="White"
                               FontSize="20"
                               HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Btn_Exit" Property="Background" Value="#3a3a3a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Btn_Exit" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <Border Grid.Column="0" Grid.ColumnSpan="8" Grid.Row="0"
        Background="#2C3A47" BorderBrush="#2A3A47" BorderThickness="0,0,0,1">
        </Border>

        <!--Device 버튼-->
        <Button x:Name="BtnDevice" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
        VerticalAlignment="Stretch" 
        HorizontalAlignment="Stretch" 
        BorderThickness="0"
        Padding="0"
        Cursor="Hand"
        MouseDoubleClick="btnDevice_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="15" Padding="20,10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#7A9AB8" Offset="0.0"/>
                                <GradientStop Color="#5C7A96" Offset="0.4"/>
                                <GradientStop Color="#232D36" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="DEVICE" Foreground="#B0B8C0" FontWeight="Bold" FontSize="20" HorizontalAlignment="Left"/>
                            <TextBlock Text="INSPECTOR-A" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <StackPanel Grid.Column="2" Grid.Row="0" VerticalAlignment="Center" Margin="10,0,0,0">
            <TextBlock Text="LOTID" Foreground="Gray" FontSize="20" Margin="0,0,0,2"/>
            <TextBlock Text="260312-PCB-005" Foreground="#70AD47" FontWeight="Bold" FontSize="20"/>
        </StackPanel>

        <Button x:Name="Btn_NameChange" Grid.Column="3" Grid.Row="0" VerticalAlignment="Center"
        Background="Transparent" BorderThickness="0" Cursor="Hand" MouseDoubleClick="btnVisionPlus_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="#1E2A35" CornerRadius="5" Padding="0,10">
                        <TextBlock Text="VISIONPLUS"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="35"
                           FontWeight="Bold"
                           Opacity="0.9">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="Black" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#1E2A35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>


        <Button x:Name="Btn_IP" Grid.Column="4" Grid.ColumnSpan="3" Grid.Row="0"
        VerticalAlignment="Center" HorizontalAlignment="Right"
        Margin="0,0,30,0"
        Cursor="Hand"
        Click="BtnIPPort_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="IP:" Foreground="Gray" FontSize="20"/>
                    <TextBlock Text="192.168.0.100" Foreground="White" FontSize="20"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="PORT:" Foreground="#999999" FontSize="20"/>
                    <TextBlock Text="9888" Foreground="White" FontSize="20"/>
                </StackPanel>
            </StackPanel>
        </Button>

        <StackPanel Grid.Column="7" Grid.Row="0" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Right" 
            Margin="0,0,20,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Ver." Foreground="Gray" FontSize="20"/>
                <TextBlock Text="2026.04.17.001" Foreground="White" FontSize="20" Margin="5,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5,0,0">
                <TextBlock x:Name="TxtCurrentTime"
                   Text="2026.04.17 16:56:00" 
                   Foreground="White" 
                   FontSize="20" 
                   VerticalAlignment="Center"/>

                <TextBlock Text=" &#xE121;" 
           FontFamily="Segoe MDL2 Assets"
           FontSize="16" 
           VerticalAlignment="Center" 
           Margin="0,0,0,0">

                    <TextBlock.Foreground>
                        <SolidColorBrush Color="#FFFFFF"/>
                    </TextBlock.Foreground>

                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FFFF" 
                          BlurRadius="15" 
                          ShadowDepth="0" 
                          Opacity="1.0" />
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>

        </StackPanel>
        
        <!-- 툴바 버튼 (Row=1, Column=1~4) -->
        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" 
        Background="#1E1E1E" Margin="3,5,3,5" CornerRadius="5">
            <WrapPanel Orientation="Horizontal" Margin="5,3" VerticalAlignment="Center">

                <!-- Grab -->
                <Button x:Name="Btn_Grab" Cursor="Hand" Margin="3,2" Padding="10,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                            BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Grab" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Live -->
                <Button x:Name="Btn_Live" Cursor="Hand" Margin="3,2" Padding="10,5" Click="LiveButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                            BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE102;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Live" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Test -->
                <Button x:Name="Btn_Test" Cursor="Hand" Margin="3,2" Padding="10,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                            BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xF6FA;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Test" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Settings -->
                <Button x:Name="Btn_Settings" Cursor="Hand" Margin="3,2" Padding="10,5" Click="btnSettings_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                            BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Settings" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Load -->
                <Button x:Name="Btn_Load" Cursor="Hand" Margin="3,2" Padding="10,5" Click="btnLoad_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                            BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Load" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Save -->
                <Button x:Name="Btn_Save" Cursor="Hand" Margin="3,2" Padding="10,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                            BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Save" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Measure -->
                <Button x:Name="Btn_Measure" Cursor="Hand" Margin="3,2" Padding="10,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" BorderBrush="#555860"
                            BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xED5E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="22" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Measure" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#3A3D42"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </WrapPanel>
        </Border>
        
        <!--User Level(Combobox)-->
        <Grid Grid.Column="7" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="User Level:" Foreground="Gray" FontSize="20" 
               VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0"/>

            <ComboBox Grid.Column="1"
          x:Name="cmbUserLevel"
          SelectedIndex="2"
          Foreground="White"
          FontSize="20"
          VerticalAlignment="Stretch"
          Margin="0,5,0,5"
          VerticalContentAlignment="Center"
          Padding="5,0">

                <ComboBox.Resources>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#3A3D42"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#4A5A6A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3A3D42"/>
                                        </Trigger>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="#4A5A6A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ComboBox.Resources>

                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="MainBorder"
                Background="#3A3D42"
                CornerRadius="5"
                BorderBrush="#555860"
                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>

                                <ToggleButton Grid.ColumnSpan="2"
                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                              BorderThickness="0">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <ContentPresenter Grid.Column="0"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"
                                  Margin="8,0,0,0"/>

                                <TextBlock Grid.Column="1"
                           Text="&#x25BC;"
                           FontSize="10"
                           Foreground="White"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           IsHitTestVisible="False"/>

                                <Popup x:Name="PART_Popup"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       Placement="Bottom"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide">
                                    <Border Background="#3A3D42"
                            BorderBrush="#555860"
                            BorderThickness="1"
                            CornerRadius="5"
                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#4A5A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ComboBox.Template>

                <ComboBoxItem Content="Operator"/>
                <ComboBoxItem Content="Engineer"/>
                <ComboBoxItem Content="Admin"/>
            </ComboBox>
        </Grid>


        <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Grid.RowSpan="4" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="Cam1Border"
    Grid.Row="0"
    Grid.Column="0"
    Grid.ColumnSpan="1"
    BorderBrush="Gray"
    BorderThickness="1"
    Margin="3"
    Background="Black"
    Cursor="Hand"
    PreviewMouseLeftButtonDown="CamBorder_PreviewMouseLeftButtonDown">
                <Grid ClipToBounds="True"
          Background="#00000001"
          MouseWheel="imgCam1_MouseWheel"
          MouseLeftButtonDown="imgCam1_MouseLeftButtonDown"
          MouseLeftButtonUp="imgCam1_MouseLeftButtonUp"
          MouseMove="imgCam1_MouseMove">
                    <TextBlock x:Name="Cam1Title"
               Text="CAM 1"
               Foreground="White"
               Margin="5"
               VerticalAlignment="Top"
               HorizontalAlignment="Left"
               Panel.ZIndex="1"/>

                    <Image x:Name="imgCam1"
           Stretch="Uniform"
           RenderTransformOrigin="0.5,0.5"/>
                </Grid>
            </Border>
            <Border x:Name="Cam2Border" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="1" BorderBrush="Gray" BorderThickness="1" Margin="3" Background="Black" Cursor="Hand" PreviewMouseLeftButtonDown="CamBorder_PreviewMouseLeftButtonDown">
                <TextBlock x:Name="Cam2Title" Text="CAM 2" Foreground="White" Margin="5"/>
            </Border>
            <Border x:Name="Cam3Border" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="1" BorderBrush="Gray" BorderThickness="1" Margin="3" Background="Black" Cursor="Hand" PreviewMouseLeftButtonDown="CamBorder_PreviewMouseLeftButtonDown">
                <TextBlock x:Name="Cam3Title" Text="CAM 3" Foreground="White" Margin="5"/>
            </Border>
            <Border x:Name="Cam4Border" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="1" BorderBrush="Gray" BorderThickness="1" Margin="3" Background="Black" Cursor="Hand" PreviewMouseLeftButtonDown="CamBorder_PreviewMouseLeftButtonDown">
                <TextBlock x:Name="Cam4Title" Text="CAM 4" Grid.ColumnSpan="1" Foreground="White" Margin="5"/>
            </Border>
            <Border x:Name="Cam5Border" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="1" BorderBrush="Gray" BorderThickness="1" Margin="3" Background="Black" Cursor="Hand" PreviewMouseLeftButtonDown="CamBorder_PreviewMouseLeftButtonDown">
                <TextBlock x:Name="Cam5Title" Text="CAM 5" Foreground="White" Margin="5"/>
            </Border>
            <Border x:Name="Cam6Border" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="1" BorderBrush="Gray" BorderThickness="1" Margin="3" Background="Black" Cursor="Hand" PreviewMouseLeftButtonDown="CamBorder_PreviewMouseLeftButtonDown">
                <TextBlock x:Name="Cam6Title" Text="CAM 6" Foreground="White" Margin="5"/>
            </Border>
        </Grid>

        <Border Grid.Row="2" Grid.Column="5" Grid.ColumnSpan="3" Background="#252526" Margin="5,0,10,0" CornerRadius="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- PASS RATE + Reset -->
                    <RowDefinition Height="Auto"/>
                    <!-- 원 게이지 (고정 높이로) -->
                    <RowDefinition Height="Auto"/>
                    <!-- CAM 탭 헤더 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 컬럼 헤더 -->
                    <RowDefinition Height="*"/>
                    <!-- 로그 리스트 ← * 로 변경 -->
                </Grid.RowDefinitions>

                <!-- PASS RATE + Reset -->
                <Grid Grid.Row="0" Margin="10,10,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="PASS RATE" Foreground="White" FontSize="20" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Reset" Background="#3A3D42" FontSize="20" Foreground="White" BorderThickness="0" Click="Btn_Reset_Click"/>
                </Grid>

                <!-- 원 게이지 -->
                <Grid Grid.Row="1" Height="180">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="269*"/>
                        <ColumnDefinition Width="12*"/>
                    </Grid.ColumnDefinitions>
                    <Canvas Width="180" Height="180" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="51,0,0,0">

                        <!-- 배경 원 (회색) -->
                        <Path Stroke="#333333" StrokeThickness="12" Fill="Transparent"
              Canvas.Left="0" Canvas.Top="0">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="90,16" IsClosed="False">
                                        <ArcSegment Point="90,164" Size="74,74" IsLargeArc="True"  SweepDirection="Clockwise"/>
                                        <ArcSegment Point="90,16"  Size="74,74" IsLargeArc="True"  SweepDirection="Clockwise"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                        </Path>

                        <!-- 게이지 원 -->
                        <Path x:Name="GaugePath" StrokeThickness="12" Fill="Transparent"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
              Canvas.Left="0" Canvas.Top="0">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure x:Name="GaugeFigure" StartPoint="90,16" IsClosed="False">
                                        <ArcSegment x:Name="GaugeArc"
                                    Point="90,15"
                                    Size="74,74"
                                    IsLargeArc="False"
                                    SweepDirection="Clockwise"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                        </Path>

                        <!-- 퍼센트 텍스트 -->
                        <TextBlock x:Name="TxtPassRate"
                   Text="0.0%"
                   Foreground="White"
                   FontSize="26"
                   FontWeight="Bold"
                   Canvas.Left="0" Canvas.Top="68"
                   Width="180"
                   TextAlignment="Center"/>
                    </Canvas>
                </Grid>

                <!-- CAM 탭 버튼 -->
                <Border Grid.Row="2" Background="#1E1E1E" Margin="5,5,5,0" CornerRadius="3">
                    <UniformGrid Rows="1" Columns="6">
                        <Button Content="ALL"   Background="#4A4A6A" Foreground="White"   BorderThickness="0" FontSize="20" Padding="4,4"/>
                        <Button Content="CAM 1" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" FontSize="20" Padding="2,4"/>
                        <Button Content="CAM 2" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" FontSize="20" Padding="2,4"/>
                        <Button Content="CAM 3" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" FontSize="20" Padding="2,4"/>
                        <Button Content="CAM 4" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" FontSize="20" Padding="2,4"/>
                        <Button Content="CAM 5" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" FontSize="20" Padding="2,4"/>
                    </UniformGrid>
                </Border>

                <!-- 컬럼 헤더 -->
                <Grid Grid.Row="3" Background="#1A1A1A" Margin="5,2,5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.5*"/>
                        <ColumnDefinition Width="Auto"/>
                        <!-- 구분선 -->
                        <ColumnDefinition Width="1.6*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="TIME"   Foreground="white" FontSize="20" Padding="4,3" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- 구분선 -->
                    <Rectangle Grid.Column="1" Width="1" Fill="White" VerticalAlignment="Stretch" Margin="0,3,0,3"/>

                    <TextBlock Grid.Column="2" Text="STATUS" Foreground="white" FontSize="20" Padding="2,3" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- 로그 리스트 -->
                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="5,2,5,5">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="6"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid Background="Transparent" Width="6">
                                            <!-- 트랙 배경 (어두운 회색) -->
                                            <Border Background="#2A2A2A" CornerRadius="3" Margin="1,0"/>
                                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <!-- 썸 (밝은 회색, 둥글게) -->
                                                                <Border Background="#666666" CornerRadius="3"/>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ScrollViewer.Resources>

                    <ItemsControl x:Name="LogList">
                        <!-- 미리보기용 샘플 데이터 -->
                        <d:ItemsControl.Items>
                            <local:LogItem Time="16:34:00.000" Status="Mode : AutoRun"/>
                            <local:LogItem Time="16:34:01.000" Status="1 Ready ON"/>
                            <local:LogItem Time="16:34:02.356" Status="Mode : Stop"/>
                            <local:LogItem Time="16:34:03.554" Status="1 Ready OFF"/>
                            <local:LogItem Time="16:34:04.432" Status="All Reset"/>
                            <local:LogItem Time="16:34:05.765" Status="Open Server socket"/>
                        </d:ItemsControl.Items>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1" Cursor="Hand" MouseLeftButtonDown="LogItem_Click" MouseRightButtonDown="LogItem_RightClick">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.5*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="1.6*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 선택 시 배경색 -->
                                    <Border Grid.ColumnSpan="3" x:Name="HighlightBorder" Background="Transparent" CornerRadius="3"/>

                                    <TextBlock Grid.Column="0" Text="{Binding Time}"   Foreground="White" FontSize="20" Padding="4,2" HorizontalAlignment="Center"/>
                                    <Rectangle Grid.Column="1" Width="1" Fill="White" VerticalAlignment="Stretch" Margin="0,2,0,2"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="White" FontSize="20" Padding="2,2"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Grid.Column="5" Grid.ColumnSpan="3" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2D2D30" Margin="5,5,5,5" CornerRadius="5">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="TOTAL (UNITS)" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalUnits" Text="0" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#2D2D30" Margin="5,5,5,5" CornerRadius="5">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="TOTAL (OK)" Foreground="#70AD47" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalOk" Text="0" Foreground="#70AD47" FontSize="20" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#442222" Margin="5,5,5,5" CornerRadius="5">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="TOTAL (NG)" Foreground="#FF6B6B" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalNg" Text="0" Foreground="#FF6B6B" FontSize="20" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>