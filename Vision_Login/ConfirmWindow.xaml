<Window x:Class="Vision_Login.ConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vision_Login"
        mc:Ignorable="d"
        Title="ConfirmWindow" Height="300" Width="550"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">
    
    <!--<Border Background="#000000" CornerRadius="25" BorderBrush="#4FB0D6" BorderThickness="1.5" >
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Color="#4FB0D6" Opacity="0.4" ShadowDepth="0"/>
        </Border.Effect>-->

    <!-- 그림자용 외부 Border -->
    <Border Margin="10" CornerRadius="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Color="#4FB0D6" Opacity="0.4" ShadowDepth="0"/>
        </Border.Effect>

        <!-- 내용용 내부 Border -->
        <Border Background="#000000" CornerRadius="25" BorderBrush="#4FB0D6" BorderThickness="1.5"
            ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="25,20,0,0">
                    <TextBlock x:Name="TxtIcon" Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" Foreground="#FF4C4C" FontSize="22" VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF4C4C" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <!--<TextBlock Text="SYSTEM SAVE" Foreground="White" FontSize="12" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>-->
                    <TextBlock x:Name="TxtTitle" Text="" Foreground="White" FontSize="22" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!--<TextBlock Text="디바이스를 저장하시겠습니까?" Foreground="White" FontSize="26" FontWeight="Bold">-->
                    <TextBlock x:Name="TxtMessage" Text="" Foreground="White" FontSize="26" FontWeight="Bold">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#4FB0D6" BlurRadius="25" ShadowDepth="0" Opacity="0.7"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <!--<TextBlock Text="설정된 파라미터가 시스템에 영구 저장됩니다." Foreground="#444" FontSize="13" Margin="0,12,0,0" HorizontalAlignment="Center"/>-->
                    <TextBlock x:Name="TxtSubMessage" Text="" Foreground="White" FontSize="13" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Row="2" Margin="30,0,30,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnYes" Grid.Column="0" Content="예" Height="55" Margin="10" Cursor="Hand" Click="btnYes_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="#111" BorderBrush="#333" BorderThickness="1.5" CornerRadius="15">
                                    <TextBlock x:Name="btnText" Text="예"
                   Foreground="#888" FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="Transparent"/>
                                        <Setter TargetName="btnBorder" Property="BorderBrush" Value="#4FB0D6"/>
                                        <Setter TargetName="btnBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#4FB0D6" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="btnText" Property="Foreground" Value="#4FB0D6"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnNo" Grid.Column="1" Content="아니오" Height="55" Margin="10" Cursor="Hand" Click="btnNo_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="#111" BorderBrush="#333" BorderThickness="1.5" CornerRadius="15">
                                    <TextBlock x:Name="btnText" Text="아니오"
                   Foreground="#888" FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="Transparent"/>
                                        <Setter TargetName="btnBorder" Property="BorderBrush" Value="#4FB0D6"/>
                                        <Setter TargetName="btnBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#4FB0D6" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="btnText" Property="Foreground" Value="#4FB0D6"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
