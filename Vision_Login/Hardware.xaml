<Window x:Class="Vision_Login.Hardware"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vision_Login"
        mc:Ignorable="d"
        Title="Hardware"
        Height="700"
        Width="1100"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#11181F">

    <Window.Resources>
        <!-- 공통 ComboBox 스타일 -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2D5D87"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="MainBorder"
                                Background="#0F1620"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="35"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton Grid.ColumnSpan="2"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              BorderThickness="0">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  IsHitTestVisible="False"
                                                  Margin="12,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="▾"
                                           FontSize="30" Foreground="White"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           IsHitTestVisible="False"/>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide">
                                    <Border Background="#0F1620"
                                            BorderBrush="#2D5D87"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#4A8EC5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 공통 ComboBoxItem 스타일 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0F1620"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B2A3A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1B3A5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE839;" FontFamily="Segoe MDL2 Assets"
Foreground="White" FontSize="25" VerticalAlignment="Center" Margin="8,0,10,0"/>
                <TextBlock Text="HARDWARE" Foreground="White"
FontSize="25" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,24,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="✕" FontSize="18"
                    Foreground="White" Background="Transparent"
                    BorderThickness="0" Cursor="Hand"
                    Click="btnClose_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="Transparent" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#253545"/>
                                            <Setter Property="Foreground" Value="#FF4757"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- 설정 영역 -->
        <Border Grid.Row="2"
                Background="#161F29"
                BorderBrush="#294861"
                BorderThickness="1"
                CornerRadius="10"
                Padding="30">
            <StackPanel>

                <!-- CAM Count -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CAM Count" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    <ComboBox x:Name="Cb_CAMCount" Grid.Column="1" SelectedIndex="5">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="6"/>
                        <ComboBoxItem Content="7"/>
                        <ComboBoxItem Content="8"/>
                    </ComboBox>
                </Grid>

                <!-- CAM Set -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CAM Set" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    <ComboBox x:Name="Cb_CAMSet" Grid.Column="1" SelectedIndex="0">
                        <ComboBoxItem Content="CAM 1"/>
                        <ComboBoxItem Content="CAM 2"/>
                        <ComboBoxItem Content="CAM 3"/>
                        <ComboBoxItem Content="CAM 4"/>
                        <ComboBoxItem Content="CAM 5"/>
                        <ComboBoxItem Content="CAM 6"/>
                        <ComboBoxItem Content="CAM 7"/>
                        <ComboBoxItem Content="CAM 8"/>
                    </ComboBox>
                </Grid>

                <!-- Image Size (pixel) -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Image Size (pixel)" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Size X -->
                        <TextBlock Text="Size X" Foreground="White" FontSize="20"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Border Background="#0F1620" BorderBrush="#2D5D87" BorderThickness="1"
        CornerRadius="5" Width="200" Height="45">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtSizeX" Grid.Column="0"
                 Text="1920" Foreground="White" Background="Transparent"
                 BorderThickness="0" FontSize="20"
                 VerticalAlignment="Center" Padding="10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <RepeatButton Content="▲" FontSize="9" Height="22" Cursor="Hand"
                          Click="BtnSizeXUp_Click">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                        <RepeatButton.Foreground>
                                            <SolidColorBrush Color="White"/>
                                        </RepeatButton.Foreground>
                                    </RepeatButton>
                                    <RepeatButton Content="▼" FontSize="9" Height="22" Cursor="Hand"
                          Click="BtnSizeXDown_Click">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                        <RepeatButton.Foreground>
                                            <SolidColorBrush Color="White"/>
                                        </RepeatButton.Foreground>
                                    </RepeatButton>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- Size Y -->
                        <TextBlock Text="Size Y" Foreground="White" FontSize="20"
                                   VerticalAlignment="Center" Margin="30,0,10,0"/>
                        <Border Background="#0F1620" BorderBrush="#2D5D87" BorderThickness="1"
        CornerRadius="5" Width="200" Height="45">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtSizeY" Grid.Column="0"
                 Text="1080" Foreground="White" Background="Transparent"
                 BorderThickness="0" FontSize="20"
                 VerticalAlignment="Center" Padding="10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <RepeatButton Content="▲" FontSize="9" Height="22" Cursor="Hand"
                          Click="BtnSizeYUp_Click">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                        <RepeatButton.Foreground>
                                            <SolidColorBrush Color="White"/>
                                        </RepeatButton.Foreground>
                                    </RepeatButton>
                                    <RepeatButton Content="▼" FontSize="9" Height="22" Cursor="Hand"
                          Click="BtnSizeYDown_Click">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                        <RepeatButton.Foreground>
                                            <SolidColorBrush Color="White"/>
                                        </RepeatButton.Foreground>
                                    </RepeatButton>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Grabber -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Grabber" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    <ComboBox x:Name="Cb_Grabber" Grid.Column="1"
                              SelectionChanged="Cb_Grabber_SelectionChanged" SelectedIndex="0">
                        <ComboBoxItem Content="Coaxlink"/>
                        <ComboBoxItem Content="Grablink Base"/>
                        <ComboBoxItem Content="Grablink Full"/>
                        <ComboBoxItem Content="Grablink DualBase_A"/>
                        <ComboBoxItem Content="Grablink DualBase_B"/>
                        <ComboBoxItem Content="Gigelink"/>
                    </ComboBox>
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="20,0,0,0">
                        <Ellipse Width="18" Height="18" Fill="LimeGreen" Margin="0,0,10,0"/>
                        <TextBlock Text="Connected" Foreground="LimeGreen" FontSize="20" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- CamFile -->
                <Grid x:Name="Grid_CamFile" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="CamFile" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="#0F1620" BorderBrush="#2D5D87"
            BorderThickness="1" CornerRadius="5" Height="45">
                        <TextBox x:Name="TxtCamFile"
                 Text="C:\work(2Dmark)\CamFile\MC_A500M-35_2TAP_8bit.cam"
                 Foreground="White" Background="Transparent"
                 BorderThickness="0" FontSize="18"
                 VerticalAlignment="Center" Padding="10,0"/>
                    </Border>
                    <Button Grid.Column="2" Margin="10,0,0,0" Height="45"
            Cursor="Hand" Click="btnCamFile_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="#1B2A38" BorderBrush="#2D5D87"
                        BorderThickness="1" CornerRadius="5">
                                    <TextBlock Text="..." Foreground="White" FontSize="22"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#2B3A48"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Serial Number 영역 -->
                <Grid x:Name="Grid_Serial"
      Visibility="Collapsed"
      Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="450"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Serial Number" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="#0F1620" BorderBrush="#2D5D87"
            BorderThickness="1" CornerRadius="5" Height="45">
                        <TextBox Foreground="White" Background="Transparent"
                 BorderThickness="0" FontSize="18"
                 Text="00A47012345"
                 VerticalAlignment="Center" Padding="10,0"/>
                    </Border>
                </Grid>

                <!-- Light Controller -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Light Controller" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" SelectedIndex="0">
                        <ComboBoxItem Content="CON"/>
                        <ComboBoxItem Content="JSL"/>
                        <ComboBoxItem Content="LVS"/>
                    </ComboBox>
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="20,0,0,0">
                        <Ellipse Width="18" Height="18" Fill="LimeGreen" Margin="0,0,10,0"/>
                        <TextBlock Text="Connected" Foreground="LimeGreen" FontSize="20" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- LotID 사용 여부 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="LotID" Foreground="White" FontSize="22" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" SelectedIndex="0">
                        <ComboBoxItem Content="Use"/>
                        <ComboBoxItem Content="Not use"/>
                    </ComboBox>
                </Grid>
                <!-- Apply -->
                <Button Width="160" Height="60" Margin="0,0,10,0" Cursor="Hand" HorizontalAlignment="Right" Click="btnApply_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#1A52CC" CornerRadius="8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontWeight="SemiBold"
                               FontSize="25" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Save" Foreground="White" FontWeight="SemiBold" FontSize="25" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#2A62DC"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- Apply / Cancel 버튼 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Center">

            
        </StackPanel>

    </Grid>
</Window>