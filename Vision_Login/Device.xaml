<Window x:Class="Vision_Login.Device"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vision_Login"
        mc:Ignorable="d"
        Title="Device Management" Height="500" Width="900"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">

    <Border Background="#2D343A" CornerRadius="15" BorderBrush="#555" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Grid Grid.Row="0" Margin="0,-10,0,20">
                <TextBlock Text="Device" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="✕" Background="Transparent" Foreground="White" BorderThickness="0"
                        FontSize="20" Cursor="Hand" HorizontalAlignment="Right"
                        Click="btnClose_Click"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- 리스트뷰 -->
                <Border Grid.Column="0" CornerRadius="8"
                        BorderBrush="#444" BorderThickness="1"
                        ClipToBounds="True">
                    <ListView x:Name="lvDevices"
          Background="White"
          BorderThickness="0"
          Foreground="White"
          ScrollViewer.HorizontalScrollBarVisibility="Auto"
          ScrollViewer.VerticalScrollBarVisibility="Auto"
          MouseDoubleClick="lvDevices_DoubleClick"
          SizeChanged="lvDevices_SizeChanged"
          Loaded="lvDevices_Loaded">

                        <!-- ListView 전체 Template 커스텀 -->
                        <ListView.Template>
                            <ControlTemplate TargetType="ListView">
                                <Border CornerRadius="8" ClipToBounds="True"
                Background="White" BorderThickness="0">
                                    <DockPanel>
                                        <!-- 헤더 영역 -->
                                        <Border DockPanel.Dock="Top"
                        Background="#3A4A55"
                        CornerRadius="8,8,0,0">
                                            <GridViewHeaderRowPresenter
                        Columns="{Binding Path=View.Columns, RelativeSource={RelativeSource TemplatedParent}}"
                        SnapsToDevicePixels="True"/>
                                        </Border>
                                        <!-- 아이템 영역 ← 여기 수정 -->
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              CanContentScroll="True">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </ControlTemplate>
                        </ListView.Template>

                        <ListView.Resources>
                            <!-- 헤더 스타일 -->
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GridViewColumnHeader">
                                            <Border x:Name="HeaderBorder"
                        Background="Transparent"
                        BorderBrush="#555E68"
                        BorderThickness="0"
                        Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!-- Tag="border"인 헤더만 오른쪽 경계선 -->
                                                <Trigger Property="Tag" Value="border">
                                                    <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="0,0,1,0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <!-- 행 스타일 -->
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="4"/>
                                <Setter Property="BorderBrush" Value="#DDDDDD"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3A6EA5"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <!-- 스크롤바 스타일 -->
                            <Style TargetType="ScrollBar">
                                <Setter Property="Width" Value="6"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ScrollBar">
                                            <Grid Background="Transparent" Width="6">
                                                <Border Background="#2A2A2A" CornerRadius="3" Margin="1,0"/>
                                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                    <Track.Thumb>
                                                        <Thumb>
                                                            <Thumb.Template>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="#666666" CornerRadius="3"/>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style x:Key="NumHeaderStyle" TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GridViewColumnHeader">
                                            <!-- Num 헤더만 오른쪽 경계선 -->
                                            <Border Background="Transparent"
                        BorderBrush="#555E68"
                        BorderThickness="0,0,1,0"
                        Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.Resources>

                        <!-- 미리보기용 샘플 데이터 -->
                        <d:ListView.Items>
                            <local:DeviceItem Num="1"  Name="TEST1"/>
                            <local:DeviceItem Num="2"  Name="TEST2"/>
                            <local:DeviceItem Num="3"  Name="TEST3"/>
                            <local:DeviceItem Num="4"  Name="TEST4"/>
                            <local:DeviceItem Num="5"  Name="TEST5"/>
                            <local:DeviceItem Num="6"  Name="TEST6"/>
                            <local:DeviceItem Num="7"  Name="TEST7"/>
                            <local:DeviceItem Num="8"  Name="TEST8"/>
                            <local:DeviceItem Num="9"  Name="TEST9"/>
                            <local:DeviceItem Num="10" Name="TEST10"/>
                        </d:ListView.Items>

                        <ListView.View>
                            <GridView>
                                <GridViewColumn x:Name="colNum" Header="Num" Width="80"
                        HeaderContainerStyle="{StaticResource NumHeaderStyle}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#DDDDDD" BorderThickness="0,0,1,0"
                            Margin="-6,-3,-6,-3" Padding="6,3">
                                                <TextBlock Text="{Binding Num}" Foreground="Black"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn x:Name="colName" Header="Name" Width="300">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Foreground="Black" Padding="6,3"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <!-- 우측 패널 -->
                <StackPanel Grid.Column="2" VerticalAlignment="Top">

                    <!-- Number -->
                    <TextBlock Text="Number:" Foreground="#AAA" Margin="0,0,0,5"/>
                    <Border CornerRadius="8" Background="#444" Margin="0,0,0,15">
                        <TextBox x:Name="txtNumber" Height="35"
                                 Background="Transparent" Foreground="White"
                                 BorderThickness="0" Padding="10,8"
                                 IsReadOnly="True" Text=""/>
                    </Border>

                    <!-- Name -->
                    <TextBlock Text="Name:" Foreground="#AAA" Margin="0,0,0,5"/>
                    <Border CornerRadius="8" Background="White" Margin="0,0,0,30">
                        <TextBox x:Name="txtName" Height="35"
                                 Background="Transparent" Foreground="Black"
                                 BorderThickness="0" Padding="10,8"
                                 Text=""/>
                    </Border>

                    <!-- LOAD DEVICE -->
                    <Button x:Name="btnLoad" Height="70" Margin="0,0,0,15" Cursor="Hand" Click="btnLoad_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="LoadBorder" CornerRadius="10" Background="#4A5B6A">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xED25;" FontSize="25" FontFamily="Segoe MDL2 Assets"
                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="LOAD" Foreground="White" FontWeight="Bold"
                                                   FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="LoadBorder" Property="Background" Value="#5A7A8A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- SAVE DEVICE -->
                    <Button x:Name="btnSave" Height="70" Cursor="Hand" Click="btnSave_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="SaveBorder" CornerRadius="10" Background="#64A18F">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE74E;" FontSize="24" FontFamily="Segoe MDL2 Assets"
                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="SAVE" Foreground="White" FontWeight="Bold"
                                                   FontSize="16" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="SaveBorder" Property="Background" Value="#7AB8A5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>